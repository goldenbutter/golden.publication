{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "EnableCors": true,
  "AllowedOrigins": [
    "http://localhost:5173"
  ],
  "Auth": {
    "Issuer": "Golden.Publication.Api",
    "Audience": "Golden.Publication.Client",
    "Key": "dev-only-super-secret-signing-key-change-in-production",
    "AccessTokenHours": 24,
    "RefreshTokenHours": 24,
    "RefreshCookieName": "gp_refresh_token"
  },
  "ConnectionStrings": {
    "Publications": "Host=localhost;Database=golden_publications;Username=postgres;Password=postgres"
  }
}
