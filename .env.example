# Example environment variables (no secrets)

# Client (Vite) - leave blank to let the SPA call the proxied API path
VITE_API_BASE=""

# API - example settings
# The API is configured via Docker in production; set locally if needed
ASPNETCORE_URLS=http://+:8080

# PostgreSQL connection string — override per environment via env var
# Docker (set in docker-compose.yml environment section, no change needed):
#   ConnectionStrings__Publications=Host=postgres;Database=golden_publications;Username=golden_user;Password=golden_pass
# Local dev (override appsettings.Development.json default):
#   ConnectionStrings__Publications=Host=localhost;Database=golden_publications;Username=postgres;Password=postgres

# XML seed file path (optional — only needed on first run if DB is empty)
# PUBLICATION_XML_FILE=/app/Data/publications.xml

# Add other secrets to your own local .env (do NOT commit secrets)
# JWT_SECRET=
